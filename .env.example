# =============================================================================
# .env.example — Example .env file
# =============================================================================

ASPNETCORE_ENVIRONMENT=Development

# -----------------------------------------------------------------------------
# SQL Server
# -----------------------------------------------------------------------------
SA_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Connection Strings
# -----------------------------------------------------------------------------
ConnectionStrings__IdentityDb=Server=sqlserver,1433;Database=TicketingSystem_Identity;User Id=sa;Password=YOUR_STRONG_PASSWORD_HERE;TrustServerCertificate=True
ConnectionStrings__FinanceDb=Server=sqlserver,1433;Database=TicketingSystem_Finance;User Id=sa;Password=YOUR_STRONG_PASSWORD_HERE;TrustServerCertificate=True
ConnectionStrings__CatalogDb=Server=sqlserver,1433;Database=TicketingSystem_Catalog;User Id=sa;Password=YOUR_STRONG_PASSWORD_HERE;TrustServerCertificate=True
ConnectionStrings__SalesDb=Server=sqlserver,1433;Database=TicketingSystem_Sales;User Id=sa;Password=YOUR_STRONG_PASSWORD_HERE;TrustServerCertificate=True
ConnectionStrings__FulfillmentDb=Server=sqlserver,1433;Database=TicketingSystem_Fulfillment;User Id=sa;Password=YOUR_STRONG_PASSWORD_HERE;TrustServerCertificate=True
ConnectionStrings__AccessDb=Server=sqlserver,1433;Database=TicketingSystem_Access;User Id=sa;Password=YOUR_STRONG_PASSWORD_HERE;TrustServerCertificate=True

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
Jwt__Secret=YOUR_JWT_SECRET_MIN_32_CHARS
Jwt__Issuer=TicketingSystem
Jwt__Audience=TicketingSystemUsers
Jwt__ExpiryMinutes=60

# -----------------------------------------------------------------------------
# QR Encryption (AES-256-GCM)
# -----------------------------------------------------------------------------
QrEncryption__Key=YOUR_BASE64_ENCODED_32_BYTE_KEY

# -----------------------------------------------------------------------------
# Email — Resend
# -----------------------------------------------------------------------------
Resend__ApiKey=YOUR_RESEND_API_KEY
Resend__From=YOUR_SENDER_EMAIL

# -----------------------------------------------------------------------------
# Paystack
# -----------------------------------------------------------------------------
PaymentGateways__Paystack__PublicKey=YOUR_PAYSTACK_PUBLIC_KEY
PaymentGateways__Paystack__SecretKey=YOUR_PAYSTACK_SECRET_KEY
PaymentGateways__Paystack__WebhookSecret=YOUR_PAYSTACK_WEBHOOK_SECRET
PaymentGateways__Paystack__BaseUrl=https://api.paystack.co

# -----------------------------------------------------------------------------
# Flutterwave
# -----------------------------------------------------------------------------
PaymentGateways__Flutterwave__PublicKey=YOUR_FLUTTERWAVE_PUBLIC_KEY
PaymentGateways__Flutterwave__SecretKey=YOUR_FLUTTERWAVE_SECRET_KEY
PaymentGateways__Flutterwave__EncryptionKey=YOUR_FLUTTERWAVE_ENCRYPTION_KEY
PaymentGateways__Flutterwave__WebhookSecretHash=YOUR_FLUTTERWAVE_WEBHOOK_SECRET_HASH
PaymentGateways__Flutterwave__BaseUrl=https://api.flutterwave.com/v3

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
AllowedOrigins__0=https://localhost:5001
AllowedOrigins__1=https://localhost:5002

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
App__BaseUrl=http://localhost:8080
